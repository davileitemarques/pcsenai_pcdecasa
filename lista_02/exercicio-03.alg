algoritmo "exercicio_03"
// Função :
// Autor :
// Data : 08/06/2026
// Seção de Declarações 
var
numero: inteiro
inicio
escreva("Seu numero: ")
leia(numero)
se numero > 0 entao
escreva("Numero positivo")
fimse
se numero < 0 entao
escreva("Numero negativo")
fimse
se numero = 0 entao
escreva("Numero igual a zero")
fimse
fimalgoritmo
