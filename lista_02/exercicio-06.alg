algoritmo "exercicio-06"

var
A, B, C: real
inicio
escreva("Numero A: ")
leia(A)
escreva("Numero B: ")
leia(B)
escreva("Numero C: ")
leia(C)

se A > (C) e (B) entao
escreva("Numero A é o maior")
se C > (A) e (B) entao
escreva("Numero C é o maior")
se B > (C) e (A) entao
escreva("Numero B é o maior")
fimse
fimse
fimse
fimalgoritmo
