algoritmo "exercicio_04"
// Funçăo :
// Autor :
// Data : 08/06/2026
// Seçăo de Declaraçőes 
var
salario, aumento, resultado: real
inicio
escreva("Seu salario: ")
leia(salario)
escreva("Aumento: ")
leia(aumento)

resultado <- salario + aumento

escreva("Seu aumento é de: ", resultado)
fimalgoritmo
