algoritmo "exercicio_01"

var
a, b, c, soma: inteiro
inicio
escreva("Escreva seu numero A: ")
leia(a)
escreva("Escreva seu numero B: ")
leia(b)
escreva("Escreva seu numero C: ")
leia(c)

soma <- a + b

se soma > c entao
escreva("Soma maior que C")
senao
escreva("Soma menor que C")
fimse
fimalgoritmo
